{
  "name": "whisk-sdk",
  "type": "module",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rimraf packages/*/{dist,.turbo} site/{dist,.turbo} .turbo node_modules/.cache",
    "build": "turbo build",
    "dev": "turbo run dev",
    "dev:docs": "turbo run dev --filter=docs...",
    "test": "vitest",
    "changeset:publish": "turbo build --filter './packages/*' && changeset publish",
    "changeset:version": "changeset version",
    "check": "biome check --fix --unsafe",
    "check:graphql": "pnpm --filter @whisk/graphql check:graphql",
    "check:types": "turbo check:types && tsgo --noEmit",
    "schema:sync": "pnpm --filter @whisk/graphql schema:sync",
    "schema:sync:local": "pnpm --filter @whisk/graphql schema:sync:local"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.6",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.5.1",
    "@typescript/native-preview": "7.0.0-dev.20260205.1",
    "dotenv": "^17.2.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.14",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.23.0"
}
