{
  "name": "@steakhouse/sdk",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/steakhouse-financial/steakhouse-sdk.git",
    "directory": "packages/steakhouse"
  },
  "scripts": {
    "generate:vaults": "tsx scripts/generate-vaults.ts",
    "generate:vaults:watch": "chokidar \"src/metadata/vaults/**/*.md\" --initial -c \"pnpm generate:vaults\"",
    "build": "pnpm generate:vaults && tsup",
    "dev": "concurrently -n vaults,tsup -c blue,green \"pnpm generate:vaults:watch\" \"tsup --watch\"",
    "check:types": "tsgo --noEmit"
  },
  "type": "module",
  "main": "./dist/index.js",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "src": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./metadata": {
      "src": "./src/metadata/index.ts",
      "types": "./dist/metadata/index.d.ts",
      "default": "./dist/metadata/index.js"
    }
  },
  "dependencies": {
    "@urql/core": "catalog:",
    "@whisk/client": "0.0.19",
    "@whisk/graphql": "0.0.18",
    "gql.tada": "catalog:"
  },
  "peerDependencies": {
    "graphql": ">=16",
    "viem": ">=2"
  },
  "devDependencies": {
    "@morpho-org/blue-sdk": "^5.12.0",
    "@morpho-org/morpho-ts": "^2.4.6",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "gray-matter": "^4.0.3",
    "tsx": "^4.20.6",
    "viem": "^2.0.0",
    "zod": "^3.24.0"
  }
}
